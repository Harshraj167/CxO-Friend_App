{
  "name": "CxO-Friend Codespaces Environment",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:1": {}
  },
  "settings": {
    "terminal.integrated.defaultProfile.linux": "bash"
  },
  "extensions": [
    "dbaeumer.vscode-eslint",
    "esbenp.prettier-vscode",
    "ms-python.python",
    "prisma.prisma",
    "ms-azuretools.vscode-docker"
  ],
  "forwardPorts": [3000, 8000, 8001, 5432],
  "portsAttributes": {
    "3000": {
      "label": "React Frontend Development Server",
      "onAutoForward": "openBrowser"
    },
    "8000": {
      "label": "Node.js API Gateway",
      "onAutoForward": "silent"
    },
    "8001": {
      "label": "Python AI Orchestrator",
      "onAutoForward": "silent"
    },
    "5432": {
      "label": "PostgreSQL Database Server",
      "onAutoForward": "silent"
    }
  },
  "postCreateCommand": "bash .devcontainer/setup-codespace.sh"
}
